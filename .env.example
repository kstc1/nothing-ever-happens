# Deployment mode (secrets and toggles only — everything else is in config.json)
BOT_MODE=paper
DRY_RUN=true
LIVE_TRADING_ENABLED=false

# Secrets
PRIVATE_KEY=
# Required for signature_type 1 or 2 live accounts
FUNDER_ADDRESS=
# Required for BOT_MODE=live
DATABASE_URL=
# Required for proxy-wallet approval bootstrap in live signature_type=2 mode
POLYGON_RPC_URL=

# Notes:
# - Keep only secrets and runtime flags in .env. Non-secret runtime settings live in config.json
#   (see config.example.json). Required secrets for live trading:
#   - PRIVATE_KEY (required)
#   - DATABASE_URL (required for durable live recovery)
#   - POLYGON_RPC_URL (required for proxy-wallet signature_type=2 approval bootstrap)
#   - FUNDER_ADDRESS (required for signature_type 1 or 2; may also be set in config.json.connection.funder_address)
# - Telegram credentials are optional and also belong in .env.

# Config file path (default: config.json)
# CONFIG_PATH=config.json

# Telegram Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
